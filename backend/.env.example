PROJECT_NAME=suportum-api
API_VERSION=1.0.0
SECRET_KEY=<genera con: python -c "import secrets; print(secrets.token_hex(64))">

# Directorios de datos
# Dejar vacios en desarrollo: el servidor usa el temp del sistema operativo automaticamente.
#   Windows dev: %TEMP%\suportum\data\suportum.db
#   Linux dev:   /tmp/suportum/data/suportum.db
#
# En produccion (VPS), /tmp se borra al reiniciar.
# Definir rutas absolutas persistentes fuera del directorio del proyecto:
#   DATABASE_URL=/home/opc/suportum-data/db/suportum.db
#   UPLOAD_DIR=/home/opc/suportum-data/uploads
#
# Crear los directorios en el VPS antes del primer deploy:
#   mkdir -p /home/opc/suportum-data/db /home/opc/suportum-data/uploads
DATABASE_URL=
UPLOAD_DIR=

CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development
PORT=8001
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION_PX=1920

# Rate limiting: max mensajes Socket.IO por usuario en la ventana de tiempo
SOCKET_MSG_RATE_MAX=30
SOCKET_MSG_RATE_WINDOW=60

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Retension de mensajes: se eliminan automaticamente los mas viejos que esto (con sus archivos en disco)
MESSAGE_RETENTION_DAYS=60
